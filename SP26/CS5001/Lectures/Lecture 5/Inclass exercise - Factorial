def factorial(n):     # Recursive factorial with print statements for tracing
    print(f"Computing factorial({n})")
    
    # Base case - covers special cases
    if n == 1 or n == 0:
        return 1
    # Recursive case - must count down to base case so n-1
    else:
        return n * factorial(n-1)

